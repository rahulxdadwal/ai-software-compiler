# AI Platform Compiler — Environment Configuration
# Copy this file to .env and fill in values

# OpenAI API Key (optional — mock mode works without it)
OPENAI_API_KEY=

# Set to "true" to use deterministic mock responses (no API key needed)
MOCK_MODE=true

# OpenAI model to use when not in mock mode
OPENAI_MODEL=gpt-4o

# Backend settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend settings
NEXT_PUBLIC_API_URL=http://localhost:8000
